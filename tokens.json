{
  "$schema": "Calmido design-system tokens — source of truth. tokens.css is generated from this file via scripts/build-tokens.mjs.",
  "$prefixes": {
    "color":    "--c-",
    "font-ink": "--c-font-",
    "font":     "--font-",
    "spacing":  "--sp-",
    "radius":   "--r-"
  },
  "color": [
    { "comment": "Calmido colour tokens (exact values from CSS styles frame)" },
    { "name": "blue",          "value": "#07369E", "note": "Calmido Blue — headlines, primary ink on light" },
    { "name": "bright-blue",   "value": "#2050FF", "note": "action accent, links" },
    { "name": "dark-blue",     "value": "#081748", "note": "primary ink on light, dark surfaces" },
    { "name": "logo-blue",     "value": "#05028E", "note": "canonical brand blue — logo art only" },
    { "name": "body-ink",      "value": "#3A4268", "note": "body prose on light" },
    { "name": "dark-green",    "value": "#10C186", "note": "primary action / link" },
    { "name": "bright-green",  "value": "#40EDAB", "note": "accent / filled-button bg" },
    { "name": "tonal-green",   "value": "#DBF6ED", "note": "tonal button bg" },
    { "name": "bg-dark",       "value": "#202128" },
    { "name": "infocard-dark", "value": "#16171C" },
    { "name": "mid-grey",      "value": "#C1C3EB" },
    { "name": "dark-grey",     "value": "#6F797A", "note": "outlined border / secondary ink" },
    { "name": "light-grey",    "value": "#DADBE0" },
    { "name": "light-bg",      "value": "#FBFBFB" },
    { "name": "white",         "value": "#FFFFFF" },
    { "name": "stop-red",      "value": "#FF3260" },
    { "name": "alert-red",     "value": "#FD5240" },
    { "name": "dark-red",      "value": "#690005" },

    { "comment": "neutrals observed in canvas (f7f7f8 base, 242 238 237 warm)" },
    { "name": "canvas",        "value": "#F7F7F8" },
    { "name": "canvas-warm",   "value": "#F2EEED" },

    { "comment": "ink on buttons (observed in Figma button specs)" },
    { "name": "filled-label",   "value": "#030815" },
    { "name": "outlined-label", "value": "#004F54" },
    { "name": "tonal-label",    "value": "#324D4D" }
  ],
  "font-ink": [
    { "comment": "Re-points to brand colours. Add class=\"inverse\" on a parent to flip all three tokens to their inverse pairs (e.g. on dark surfaces)." },
    { "name": "title",          "value": "{color.blue}" },
    { "name": "title-inverse",  "value": "{color.white}" },
    { "name": "body",           "value": "{color.dark-blue}" },
    { "name": "body-inverse",   "value": "#FFFFFFBF", "note": "white @ 75%" },
    { "name": "muted",          "value": "{color.dark-grey}" },
    { "name": "muted-inverse",  "value": "#FFFFFF99", "note": "white @ 60%" }
  ],
  "font": [
    { "comment": "Font families — three free / Google Fonts" },
    { "name": "display", "value": "\"Geologica\", system-ui, -apple-system, Segoe UI, sans-serif" },
    { "name": "body",    "value": "\"Open Sans\",  system-ui, -apple-system, Segoe UI, sans-serif" },
    { "name": "mono",    "value": "\"Courier Prime\", ui-monospace, Menlo, monospace" }
  ],
  "spacing": [
    { "comment": "Spacing scale — multiples of 4px" },
    { "name": "1",  "value": "4px"  },
    { "name": "2",  "value": "8px"  },
    { "name": "3",  "value": "12px" },
    { "name": "4",  "value": "16px" },
    { "name": "5",  "value": "20px" },
    { "name": "6",  "value": "24px" },
    { "name": "8",  "value": "32px" },
    { "name": "10", "value": "40px" },
    { "name": "12", "value": "48px" },
    { "name": "16", "value": "64px" },
    { "name": "20", "value": "80px" },
    { "name": "24", "value": "96px" }
  ],
  "radius": [
    { "comment": "Radii observed: 4 (input), 16 (card), 20 (pill input), 30 (avatar btn), 100 (button/switch)" },
    { "name": "sm",   "value": "4px"   },
    { "name": "md",   "value": "12px"  },
    { "name": "lg",   "value": "16px"  },
    { "name": "pill", "value": "100px" }
  ]
}
